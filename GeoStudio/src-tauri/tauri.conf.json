{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GeoStudio",
  "version": "0.1.0",
  "identifier": "com.geostudio.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GeoStudio",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}
